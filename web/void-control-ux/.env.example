# Bridge URL the dashboard talks to for launch/upload and (via the Vite
# proxy) for daemon-backed inspection. The bridge is the only HTTP/TCP
# endpoint the browser hits; it dispatches to the daemon over AF_UNIX or
# TCP under the hood.
VITE_VOID_CONTROL_BASE_URL=http://127.0.0.1:43210

# Setting VITE_VOID_BOX_BASE_URL is only useful when the daemon listens on
# TCP behind a CORS-aware reverse proxy. The default daemon listener is
# AF_UNIX and unreachable from a browser; leave this unset to use the
# Vite `/api` -> bridge proxy.
# VITE_VOID_BOX_BASE_URL=http://127.0.0.1:43100
